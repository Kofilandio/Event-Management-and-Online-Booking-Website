# Large recommendation dataset (provided on e-class — do not commit, ~1.5GB).
# Keep ONLY the small event_interest.csv (~632 KB) so `npm run eval:recommender`
# runs out of the box; the giant CSVs (events/users/attendees/friends) stay out.
rel_event_csvs/*
!rel_event_csvs/event_interest.csv

